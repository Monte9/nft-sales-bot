{
  "name": "nft-flipping-mcbot",
  "version": "1.0.0",
  "description": "A Twitter bot that tweets about NFT sales along with the flipping %",
  "main": "index.ts",
  "scripts": {
    "clean": "rm -rf build && mkdir build",
    "clean-install": "rm -rf node_modules && yarn clean && yarn",
    "build": "npm run clean && babel -d ./build ./src -s --extensions '.js,.ts,.tsx'",
    "tsc": "tsc",
    "start": "node build/index.js",
    "start:dev": "nodemon --exec babel-node src/index.ts --extensions '.js,.ts,.tsx'"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/Monte9/nft-flipping-mcbot.git"
  },
  "author": "monte9",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Monte9/nft-flipping-mcbot/issues"
  },
  "homepage": "https://github.com/Monte9/nft-flipping-mcbot#readme",
  "dependencies": {
    "@babel/cli": "^7.14.5",
    "@babel/plugin-transform-runtime": "^7.14.5",
    "@babel/runtime": "^7.14.6",
    "dotenv": "^10.0.0",
    "moment": "^2.29.1",
    "node-fetch": "^2.6.1",
    "twit": "^2.2.11"
  },
  "devDependencies": {
    "@babel/core": "^7.14.6",
    "@babel/node": "^7.14.7",
    "@babel/preset-env": "^7.14.7",
    "@babel/preset-typescript": "^7.14.5",
    "@types/node": "^16.4.10",
    "nodemon": "^2.0.12",
    "typescript": "^4.3.5"
  }
}
