{
  "name": "nft-sales-bot",
  "version": "1.0.0",
  "description": "A Twitter bot reporting crazy flips and fumbles for NFT collections.",
  "main": "index.ts",
  "scripts": {
    "clean": "rm -rf build && mkdir build",
    "clean-install": "rm -rf node_modules && yarn clean && yarn",
    "lint": "eslint . --ext .ts --cache --fix",
    "prettify": "prettier --config .prettierrc 'src/**/*.ts' --write",
    "dev": "nodemon --exec babel-node src/salesbot.ts --extensions '.js,.ts,.tsx'",
    "build": "yarn clean && babel -d ./build ./src -s --extensions '.js,.ts,.tsx'",
    "start": "node build/salesbot.js",
    "prepare": "husky install"
  },
  "engines": {
    "node": "^18.15.0",
    "npm": "^9.5.0",
    "yarn": "^1.22.19"
  },
  "dependencies": {
    "@babel/runtime": "^7.14.6",
    "dotenv": "^10.0.0",
    "magic-bytes.js": "^1.0.8",
    "moment-timezone": "^0.5.33",
    "node-fetch": "^2.6.1",
    "twitter-api-v2": "^1.11.1"
  },
  "devDependencies": {
    "@babel/cli": "^7.17.6",
    "@babel/core": "^7.14.6",
    "@babel/node": "^7.14.7",
    "@babel/plugin-transform-runtime": "^7.17.0",
    "@babel/preset-env": "^7.14.7",
    "@babel/preset-typescript": "^7.14.5",
    "@types/node": "^16.4.10",
    "@typescript-eslint/eslint-plugin": "^5.16.0",
    "@typescript-eslint/parser": "^5.16.0",
    "eslint": "^8.11.0",
    "eslint-config-prettier": "^8.5.0",
    "eslint-plugin-prettier": "^4.0.0",
    "husky": ">=6",
    "lint-staged": ">=10",
    "nodemon": "^2.0.12",
    "prettier": "^2.6.1",
    "typescript": "^4.3.5"
  },
  "lint-staged": {
    "*.ts": [
      "yarn lint",
      "yarn prettify"
    ]
  }
}
