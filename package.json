{
  "name": "nft-sales-bot",
  "version": "1.0.0",
  "description": "A Twitter bot that tweets all NFT sales along with the profit/loss flip % for CryptoPunks, Bored Apes & Cool Cats.",
  "main": "index.ts",
  "scripts": {
    "clean": "rm -rf build && mkdir build",
    "clean-install": "rm -rf node_modules && yarn clean && yarn",
    "gql-gen": "graphql-codegen --require dotenv/config --config codegen.yml",
    "lint": "eslint . --ext .ts --cache --fix",
    "dev": "nodemon --exec babel-node src/salesbot.ts --extensions '.js,.ts,.tsx'",
    "build": "yarn clean && yarn gql-gen && babel -d ./build ./src -s --extensions '.js,.ts,.tsx'",
    "start": "node build/salesbot.js"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com:Monte9/nft-sales-bot.git"
  },
  "author": "monte9",
  "license": "ISC",
  "homepage": "https://github.com/Monte9/nft-sales-bot#readme",
  "dependencies": {
    "@babel/runtime": "^7.14.6",
    "dotenv": "^10.0.0",
    "graphql": "^16.2.0",
    "graphql-request": "^3.7.0",
    "magic-bytes.js": "^1.0.8",
    "moment-timezone": "^0.5.33",
    "node-fetch": "^2.6.1",
    "twitter-api-v2": "^1.11.1"
  },
  "devDependencies": {
    "@babel/cli": "^7.17.6",
    "@babel/core": "^7.14.6",
    "@babel/node": "^7.14.7",
    "@babel/plugin-transform-runtime": "^7.17.0",
    "@babel/preset-env": "^7.14.7",
    "@babel/preset-typescript": "^7.14.5",
    "@graphql-codegen/cli": "2.3.0",
    "@graphql-codegen/typescript": "2.4.1",
    "@graphql-codegen/typescript-resolvers": "2.4.2",
    "@types/node": "^16.4.10",
    "@typescript-eslint/eslint-plugin": "^5.16.0",
    "@typescript-eslint/parser": "^5.16.0",
    "eslint": "^8.11.0",
    "nodemon": "^2.0.12",
    "typescript": "^4.3.5"
  }
}
