{
  "name": "nft-sales-bot",
  "version": "1.0.0",
  "description": "A Twitter bot that tweets all NFT sales along with the profit/loss flip % for CryptoPunks, Bored Apes & Cool Cats.",
  "main": "index.ts",
  "scripts": {
    "clean": "rm -rf build && mkdir build",
    "clean-install": "rm -rf node_modules && yarn clean && yarn",
    "build": "npm run clean && babel -d ./build ./src -s --extensions '.js,.ts,.tsx'",
    "tsc": "tsc",
    "start": "node build/salesbot.js",
    "start:dev": "nodemon --exec babel-node src/salesbot.ts --extensions '.js,.ts,.tsx'",
    "start:leaderboard": "nodemon --exec babel-node src/leaderboard.ts --extensions '.js,.ts,.tsx'"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com:Monte9/nft-sales-bot.git"
  },
  "author": "monte9",
  "license": "ISC",
  "homepage": "https://github.com/Monte9/nft-sales-bot#readme",
  "dependencies": {
    "@babel/cli": "^7.14.5",
    "@babel/plugin-transform-runtime": "^7.14.5",
    "@babel/runtime": "^7.14.6",
    "dotenv": "^10.0.0",
    "moment-timezone": "^0.5.33",
    "node-fetch": "^2.6.1",
    "twitter-api-v2": "^1.3.0",
    "web3": "^1.5.2",
    "yargs": "^17.2.1"
  },
  "devDependencies": {
    "@babel/core": "^7.14.6",
    "@babel/node": "^7.14.7",
    "@babel/preset-env": "^7.14.7",
    "@babel/preset-typescript": "^7.14.5",
    "@types/node": "^16.4.10",
    "nodemon": "^2.0.12",
    "typescript": "^4.3.5"
  }
}
